---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;
---

<Layout title="Special Programs & Current Opportunities — Entrypoint Canada">
  <Navbar />
  <main id="main-content">

    <!-- Page hero -->
    <section style="position: relative; overflow: hidden; background: #1A0A0A; padding: 72px 0 64px; min-height: 420px; display: flex; align-items: center;">
      <img
        src={`${base}images/cole-keister-rydTSO7xB5A-unsplash.jpg`}
        alt=""
        aria-hidden="true"
        loading="eager"
        fetchpriority="high"
        style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center;"
      />
      <div style="position: absolute; inset: 0; background: rgba(10,5,5,0.65);"></div>
      <div class="page-hero-inner" style="position: relative; z-index: 1;">
        <a href={base} style="display: inline-flex; align-items: center; gap: 6px; font-family: Inter, sans-serif; font-size: 13px; color: rgba(255,255,255,0.6); text-decoration: none; margin-bottom: 24px; transition: color 0.15s;"
           onmouseover="this.style.color='rgba(255,255,255,0.9)'" onmouseout="this.style.color='rgba(255,255,255,0.6)'">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
          Back to home
        </a>
        <p style="font-family: Inter, sans-serif; font-size: 10px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: #C4973A; margin-bottom: 12px;">
          Immigration Programs
        </p>
        <h1 style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(30px, 4vw, 42px); font-weight: 700; color: #ffffff; line-height: 1.15; margin-bottom: 16px; max-width: 720px;">
          Special Programs &amp; Current Opportunities
        </h1>
        <p style="font-family: Inter, sans-serif; font-size: 17px; font-weight: 300; color: rgba(255,255,255,0.75); line-height: 1.7; max-width: 600px;">
          Immigration policy evolves constantly. These are the programs that matter most right now — time-sensitive pathways and specialist streams where expert guidance makes a measurable difference.
        </p>
      </div>
    </section>

    <!-- Section 1: Time-Sensitive Programs -->
    <section style="background: #FAF7F2; padding: 80px 0;">
      <div class="section-container">

        <div style="margin-bottom: 48px;">
          <div style="display: inline-flex; align-items: center; gap: 8px; background: #FEF3C7; border: 1px solid #C4973A; border-radius: 20px; padding: 6px 14px; margin-bottom: 20px;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#92400E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <span style="font-family: Inter, sans-serif; font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: #92400E;">Time-Sensitive</span>
          </div>
          <h2 style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(24px, 2.5vw, 32px); font-weight: 600; color: #1A1A2E; line-height: 1.2; margin-bottom: 12px;">
            Programs with Current or Recent Intake Windows
          </h2>
          <p style="font-family: Inter, sans-serif; font-size: 16px; font-weight: 300; color: #5C5C7A; line-height: 1.7; max-width: 640px;">
            These pathways have intake periods, caps, or policy windows that close. Acting during an open window may strengthen your eligibility positioning. Expert guidance helps ensure your application is complete and competitive when intake periods are active.
          </p>
          <p style="font-family: Inter, sans-serif; font-size: 12px; font-weight: 300; color: #9C9C9C; margin-top: 10px; line-height: 1.65; max-width: 640px;">
            Availability, eligibility, and intake periods may change without notice based on IRCC, provincial, or pilot program updates.
          </p>
        </div>

        <div class="grid-programs-2col">

          <!-- TR to PR Pathway -->
          <article class="program-card" style="background: #ffffff; border-radius: 10px; border: 1px solid #E8E3D9; border-top: 3px solid #D97706; overflow: hidden; display: flex; flex-direction: column;">
            <div style="padding: 24px 24px 16px;">
              <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; margin-bottom: 20px; flex-wrap: wrap;">
                <div style="background: #FEF3C7; border-radius: 8px; padding: 10px 14px;">
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#C4973A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
                  </svg>
                </div>
                <span style="font-family: Inter, sans-serif; font-size: 11px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #8B1A1A; background: #FEE2E2; padding: 4px 10px; border-radius: 12px; white-space: nowrap;">
                  Recent policy window
                </span>
              </div>
              <h3 style="font-family: 'Playfair Display', Georgia, serif; font-size: 22px; font-weight: 700; color: #1A1A2E; line-height: 1.25; margin-bottom: 12px;">
                TR to PR Pathway
              </h3>
              <p style="font-family: Inter, sans-serif; font-size: 14px; font-weight: 300; color: #5C5C7A; line-height: 1.75; margin-bottom: 24px;">
                Canada's Temporary Resident to Permanent Resident pathway offers a direct route to permanent residence for individuals already living and working in Canada. This stream prioritizes applicants who have demonstrated their integration into Canadian society.
              </p>
              <ul style="list-style: none; padding: 0; margin: 0 0 28px; display: flex; flex-direction: column; gap: 10px;">
                {[
                  'Currently holding valid temporary status in Canada',
                  'Work experience in an eligible NOC category',
                  'Language proficiency at CLB 4 or above',
                  'No criminal inadmissibility issues',
                ].map((item) => (
                  <li style="display: flex; align-items: flex-start; gap: 10px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#C4973A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="flex-shrink: 0; margin-top: 2px;"><polyline points="20 6 9 17 4 12"/></svg>
                    <span style="font-family: Inter, sans-serif; font-size: 13px; font-weight: 300; color: #3D3D5C; line-height: 1.6;">{item}</span>
                  </li>
                ))}
              </ul>
              <div style="background: #FFFBEB; border: 1px solid #F0D080; border-radius: 8px; padding: 14px 16px; margin-bottom: 24px;">
                <p style="font-family: Inter, sans-serif; font-size: 13px; font-weight: 400; color: #78350F; line-height: 1.6; margin: 0;">
                  <strong>Why act now:</strong> Intake caps can fill quickly when rounds open. Acting during an open window may improve your competitiveness. Consult with Sabiha to assess whether this pathway is currently available for your profile.
                </p>
              </div>
            </div>
            <div style="padding: 0 24px 24px; margin-top: auto;">
              <a href={`${base}contact`} class="btn-gold" style="display: inline-flex; align-items: center; gap: 8px; font-family: Inter, sans-serif; font-size: 14px; font-weight: 500; color: #1A1A2E; background: #C4973A; padding: 12px 22px; border-radius: 6px; text-decoration: none;">
                Assess my eligibility
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </div>
          </article>

          <!-- Rural Community Immigration Pilot -->
          <article class="program-card" style="background: #ffffff; border-radius: 10px; border: 1px solid #E8E3D9; border-top: 3px solid #D97706; overflow: hidden; display: flex; flex-direction: column;">
            <div style="padding: 24px 24px 16px;">
              <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; margin-bottom: 20px; flex-wrap: wrap;">
                <div style="background: #FEF3C7; border-radius: 8px; padding: 10px 14px;">
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#C4973A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                  </svg>
                </div>
                <span style="font-family: Inter, sans-serif; font-size: 11px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #065F46; background: #D1FAE5; padding: 4px 10px; border-radius: 12px; white-space: nowrap;">
                  Community-Driven
                </span>
              </div>
              <h3 style="font-family: 'Playfair Display', Georgia, serif; font-size: 22px; font-weight: 700; color: #1A1A2E; line-height: 1.25; margin-bottom: 12px;">
                Rural Community Immigration Pilot
              </h3>
              <p style="font-family: Inter, sans-serif; font-size: 14px; font-weight: 300; color: #5C5C7A; line-height: 1.75; margin-bottom: 24px;">
                Designed to address labour shortages in rural and smaller communities across Canada. Participating communities select candidates based on local employer needs, offering a community-backed pathway to permanent residence.
              </p>
              <ul style="list-style: none; padding: 0; margin: 0 0 28px; display: flex; flex-direction: column; gap: 10px;">
                {[
                  'Job offer from an eligible employer in a participating community',
                  'Meets occupational requirements (NOC TEER 0, 1, 2, or 3)',
                  'Language proficiency meeting community thresholds',
                  'Sufficient settlement funds',
                ].map((item) => (
                  <li style="display: flex; align-items: flex-start; gap: 10px;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#C4973A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="flex-shrink: 0; margin-top: 2px;"><polyline points="20 6 9 17 4 12"/></svg>
                    <span style="font-family: Inter, sans-serif; font-size: 13px; font-weight: 300; color: #3D3D5C; line-height: 1.6;">{item}</span>
                  </li>
                ))}
              </ul>
              <div style="background: #ECFDF5; border: 1px solid #6EE7B7; border-radius: 8px; padding: 14px 16px; margin-bottom: 24px;">
                <p style="font-family: Inter, sans-serif; font-size: 13px; font-weight: 400; color: #065F46; line-height: 1.6; margin: 0;">
                  <strong>Why act now:</strong> Community allocations are limited per intake period. We help identify which communities have openings that match your occupation.
                </p>
              </div>
            </div>
            <div style="padding: 0 24px 24px; margin-top: auto;">
              <a href={`${base}contact`} class="btn-gold" style="display: inline-flex; align-items: center; gap: 8px; font-family: Inter, sans-serif; font-size: 14px; font-weight: 500; color: #1A1A2E; background: #C4973A; padding: 12px 22px; border-radius: 6px; text-decoration: none;">
                Assess my eligibility
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </div>
          </article>

        </div>
      </div>
    </section>

    <!-- Section 2: Specialist Pathways -->
    <section style="background: #ffffff; padding: 80px 0;">
      <div class="section-container">

        <div style="margin-bottom: 48px;">
          <p style="font-family: Inter, sans-serif; font-size: 10px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: #1C2456; margin-bottom: 12px;">
            Specialist Streams
          </p>
          <h2 style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(24px, 2.5vw, 32px); font-weight: 600; color: #1A1A2E; line-height: 1.2; margin-bottom: 12px;">
            Pathways for Unique Profiles
          </h2>
          <p style="font-family: Inter, sans-serif; font-size: 16px; font-weight: 300; color: #5C5C7A; line-height: 1.7; max-width: 640px;">
            These work permit categories are often overlooked — but for the right applicant, they can be faster, more accessible, and more strategic than conventional pathways.
          </p>
        </div>

        <div class="grid-programs-3col">

          <!-- C11 Entrepreneur -->
          <article class="program-card" style="background: #F8F9FF; border-radius: 10px; border: 1px solid #D4D8F0; border-top: 3px solid #1C2456; padding: 24px; display: flex; flex-direction: column;">
            <div style="background: #E8EBF8; border-radius: 8px; padding: 10px 12px; display: inline-flex; margin-bottom: 20px; width: fit-content;">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#1C2456" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
              </svg>
            </div>
            <div style="display: inline-flex; margin-bottom: 12px;">
              <span style="font-family: Inter, sans-serif; font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: #1C2456; background: #D4D8F0; padding: 3px 9px; border-radius: 10px;">
                LMIA Exempt — C11
              </span>
            </div>
            <h3 style="font-family: 'Playfair Display', Georgia, serif; font-size: 19px; font-weight: 700; color: #1A1A2E; line-height: 1.3; margin-bottom: 12px;">
              C11 Entrepreneur Work Permit
            </h3>
            <p style="font-family: Inter, sans-serif; font-size: 14px; font-weight: 300; color: #5C5C7A; line-height: 1.75; margin-bottom: 20px; flex: 1;">
              For foreign nationals who intend to establish, purchase, or invest in a Canadian business. This LMIA-exempt stream allows entrepreneurs to work while building their business case for permanent residence under the Start-Up Visa or Provincial Nominee streams.
            </p>
            <ul style="list-style: none; padding: 0; margin: 0 0 24px; display: flex; flex-direction: column; gap: 8px;">
              {[
                'Business plan demonstrating significant benefit to Canada',
                'Sufficient capital or investment commitment',
                'Intent to actively manage the business',
              ].map((item) => (
                <li style="display: flex; align-items: flex-start; gap: 8px;">
                  <span style="width: 5px; height: 5px; border-radius: 50%; background: #1C2456; flex-shrink: 0; margin-top: 7px;"></span>
                  <span style="font-family: Inter, sans-serif; font-size: 13px; font-weight: 300; color: #3D3D5C; line-height: 1.6;">{item}</span>
                </li>
              ))}
            </ul>
            <a href={`${base}contact`} style="font-family: Inter, sans-serif; font-size: 13px; font-weight: 500; color: #1C2456; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; border-bottom: 1px solid #1C2456; padding-bottom: 2px; width: fit-content; transition: opacity 0.15s;"
               onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">
              Learn more
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </article>

          <!-- C16 Francophone Mobility -->
          <article class="program-card" style="background: #F8F9FF; border-radius: 10px; border: 1px solid #D4D8F0; border-top: 3px solid #1C2456; padding: 24px; display: flex; flex-direction: column;">
            <div style="background: #E8EBF8; border-radius: 8px; padding: 10px 12px; display: inline-flex; margin-bottom: 20px; width: fit-content;">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#1C2456" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            </div>
            <div style="display: inline-flex; margin-bottom: 12px;">
              <span style="font-family: Inter, sans-serif; font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: #1C2456; background: #D4D8F0; padding: 3px 9px; border-radius: 10px;">
                LMIA Exempt — C16
              </span>
            </div>
            <h3 style="font-family: 'Playfair Display', Georgia, serif; font-size: 19px; font-weight: 700; color: #1A1A2E; line-height: 1.3; margin-bottom: 12px;">
              C16 Francophone Mobility
            </h3>
            <p style="font-family: Inter, sans-serif; font-size: 14px; font-weight: 300; color: #5C5C7A; line-height: 1.75; margin-bottom: 20px; flex: 1;">
              French-speaking workers outside Quebec have access to this LMIA-exempt work permit, designed to support Canada's Francophone communities outside Quebec. It removes one of the biggest barriers in the immigration process — no Labour Market Impact Assessment required.
            </p>
            <ul style="list-style: none; padding: 0; margin: 0 0 24px; display: flex; flex-direction: column; gap: 8px;">
              {[
                'French language proficiency (oral)',
                'Valid job offer in any province except Quebec',
                'NOC TEER 0, 1, 2, or 3 occupation',
              ].map((item) => (
                <li style="display: flex; align-items: flex-start; gap: 8px;">
                  <span style="width: 5px; height: 5px; border-radius: 50%; background: #1C2456; flex-shrink: 0; margin-top: 7px;"></span>
                  <span style="font-family: Inter, sans-serif; font-size: 13px; font-weight: 300; color: #3D3D5C; line-height: 1.6;">{item}</span>
                </li>
              ))}
            </ul>
            <a href={`${base}contact`} style="font-family: Inter, sans-serif; font-size: 13px; font-weight: 500; color: #1C2456; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; border-bottom: 1px solid #1C2456; padding-bottom: 2px; width: fit-content; transition: opacity 0.15s;"
               onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">
              Learn more
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </article>

          <!-- C44 Postdoctoral -->
          <article class="program-card" style="background: #F8F9FF; border-radius: 10px; border: 1px solid #D4D8F0; border-top: 3px solid #1C2456; padding: 24px; display: flex; flex-direction: column;">
            <div style="background: #E8EBF8; border-radius: 8px; padding: 10px 12px; display: inline-flex; margin-bottom: 20px; width: fit-content;">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#1C2456" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/>
              </svg>
            </div>
            <div style="display: inline-flex; margin-bottom: 12px;">
              <span style="font-family: Inter, sans-serif; font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: #1C2456; background: #D4D8F0; padding: 3px 9px; border-radius: 10px;">
                LMIA Exempt — C44
              </span>
            </div>
            <h3 style="font-family: 'Playfair Display', Georgia, serif; font-size: 19px; font-weight: 700; color: #1A1A2E; line-height: 1.3; margin-bottom: 12px;">
              C44 Postdoctoral Research
            </h3>
            <p style="font-family: Inter, sans-serif; font-size: 14px; font-weight: 300; color: #5C5C7A; line-height: 1.75; margin-bottom: 20px; flex: 1;">
              Doctoral graduates conducting postdoctoral research at a Canadian university or research institution can access this LMIA-exempt stream. It provides a fast, streamlined path to Canadian work authorization and, for many, a bridge to Express Entry through Canadian Experience Class.
            </p>
            <ul style="list-style: none; padding: 0; margin: 0 0 24px; display: flex; flex-direction: column; gap: 8px;">
              {[
                'Doctoral degree (Canadian or foreign equivalent)',
                'Postdoctoral position at a recognized institution',
                'Research in an eligible field',
              ].map((item) => (
                <li style="display: flex; align-items: flex-start; gap: 8px;">
                  <span style="width: 5px; height: 5px; border-radius: 50%; background: #1C2456; flex-shrink: 0; margin-top: 7px;"></span>
                  <span style="font-family: Inter, sans-serif; font-size: 13px; font-weight: 300; color: #3D3D5C; line-height: 1.6;">{item}</span>
                </li>
              ))}
            </ul>
            <a href={`${base}contact`} style="font-family: Inter, sans-serif; font-size: 13px; font-weight: 500; color: #1C2456; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; border-bottom: 1px solid #1C2456; padding-bottom: 2px; width: fit-content; transition: opacity 0.15s;"
               onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">
              Learn more
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </article>

        </div>
      </div>
    </section>

    <!-- Policy note -->
    <section style="background: #F4F1EB; padding: 48px 0;">
      <div class="section-container">
        <div style="background: white; border: 1px solid #E8E3D9; border-left: 3px solid #C4973A; border-radius: 10px; padding: 28px 32px; display: flex; align-items: flex-start; gap: 20px;">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C4973A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="flex-shrink: 0; margin-top: 2px;">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
          <p style="font-family: Inter, sans-serif; font-size: 14px; font-weight: 300; color: #5C5C7A; line-height: 1.8; margin: 0;">
            <strong style="color: #1A1A2E; font-weight: 500;">This page reflects current program availability as of April 2026.</strong> Canadian immigration policy changes frequently — program caps, intake windows, and eligibility criteria can shift with little notice. Information here is for general awareness only and does not constitute regulated immigration advice. A formal consultation with Sabiha Iftakhar, RCIC, will assess your specific situation against the most current IRCC guidelines.
          </p>
        </div>
      </div>
    </section>

    <!-- Last reviewed timestamp -->
    <div style="max-width: 1200px; margin: 0 auto; padding: 20px 56px 0;">
      <p style="font-family: Inter, sans-serif; font-size: 11px; font-weight: 300; color: #9C9C9C;">Last reviewed: April 2026</p>
    </div>

    <!-- Bottom CTA -->
    <section style="background: #3D1215; padding: 80px 0;">
      <div class="section-container" style="text-align: center;">
        <p style="font-family: Inter, sans-serif; font-size: 10px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: #C4973A; margin-bottom: 16px;">
          Not Sure Where You Fit?
        </p>
        <h2 style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(24px, 2.5vw, 32px); font-weight: 600; color: #ffffff; line-height: 1.2; margin-bottom: 20px; max-width: 640px; margin-left: auto; margin-right: auto;">
          Every situation is different. Let's find your pathway together.
        </h2>
