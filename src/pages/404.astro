---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;
---

<Layout
  title="Page Not Found | Entrypoint Canada"
  description="The page you requested could not be found. Return to Entrypoint Canada to explore immigration services, programs, and consultation options."
  noindex={true}
>
  <Navbar />
  <main id="main-content">
    <section style="background: linear-gradient(180deg, #FAF7F2 0%, #F4F1EB 100%); padding: 96px 0 104px;">
      <div class="section-container" style="display: flex; justify-content: center;">
        <div style="width: 100%; max-width: 760px; background: rgba(255,255,255,0.96); border: 1px solid rgba(28,36,86,0.08); border-top: 4px solid #8B1A1A; border-radius: 24px; padding: 42px 34px; box-shadow: 0 22px 52px rgba(61,18,21,0.08); text-align: center;">
          <img
            src={`${base}logo-icon.svg`}
            alt="Entrypoint Canada"
            width="58"
            height="58"
            style="width: 58px; height: 58px; object-fit: contain; margin: 0 auto 18px; display: block;"
          />

          <p style="font-family: Inter, sans-serif; font-size: 11px; font-weight: 600; letter-spacing: 0.22em; text-transform: uppercase; color: #8B1A1A; margin-bottom: 12px;">
            Page not found
          </p>

          <h1 style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(34px, 5vw, 50px); font-weight: 700; color: #1A1A2E; line-height: 1.08; margin-bottom: 16px;">
            We couldn’t find that page.
          </h1>

          <p style="font-family: Inter, sans-serif; font-size: 15px; font-weight: 300; color: #45465E; line-height: 1.8; max-width: 560px; margin: 0 auto 18px;">
            The link may be outdated, mistyped, or tied to a URL that does not exist on the site. You can head back to the homepage or continue to the contact page if you were trying to reach the team directly.
          </p>

          <div style="display: inline-flex; align-items: center; gap: 8px; background: rgba(196,151,58,0.12); border: 1px solid rgba(196,151,58,0.28); border-radius: 999px; padding: 7px 14px; margin-bottom: 28px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#C4973A" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="12" y1="8" x2="12" y2="12"></line>
              <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
            <span style="font-family: Inter, sans-serif; font-size: 12px; font-weight: 500; color: #7A5614;">
              Invalid URLs will still return a proper 404 response.
            </span>
          </div>

          <div class="not-found-actions" style="display: flex; justify-content: center; gap: 14px; flex-wrap: wrap; margin-bottom: 28px;">
            <a href={base} class="btn-burgundy">
              Return to homepage
            </a>
            <a
              href={`${base}contact`}
              style="display: inline-flex; align-items: center; justify-content: center; min-height: 46px; padding: 0 20px; border-radius: 999px; border: 1px solid rgba(61,18,21,0.16); background: #ffffff; font-family: Inter, sans-serif; font-size: 14px; font-weight: 600; color: #3D1215; text-decoration: none; transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;"
              onmouseover="this.style.transform='translateY(-1px)';this.style.boxShadow='0 10px 22px rgba(61,18,21,0.08)';this.style.borderColor='rgba(61,18,21,0.28)'"
              onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='none';this.style.borderColor='rgba(61,18,21,0.16)'"
            >
              Contact Entrypoint Canada
            </a>
          </div>

          <div style="display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; text-align: left;" class="not-found-links">
            <a href={`${base}services`} style="background: #FAF7F2; border: 1px solid #E8E3D9; border-radius: 18px; padding: 16px 16px 18px; text-decoration: none;">
              <p style="font-family: 'Playfair Display', Georgia, serif; font-size: 18px; font-weight: 600; color: #1C2456; line-height: 1.15; margin-bottom: 8px;">Services</p>
              <p style="font-family: Inter, sans-serif; font-size: 13px; font-weight: 300; color: #45465E; line-height: 1.65;">Explore permanent residence, permits, sponsorship, and humanitarian matters.</p>
            </a>
            <a href={`${base}programs`} style="background: #FAF7F2; border: 1px solid #E8E3D9; border-radius: 18px; padding: 16px 16px 18px; text-decoration: none;">
              <p style="font-family: 'Playfair Display', Georgia, serif; font-size: 18px; font-weight: 600; color: #1C2456; line-height: 1.15; margin-bottom: 8px;">Programs</p>
              <p style="font-family: Inter, sans-serif; font-size: 13px; font-weight: 300; color: #45465E; line-height: 1.65;">Review major pathways and current immigration program categories.</p>
            </a>
            <a href={`${base}about`} style="background: #FAF7F2; border: 1px solid #E8E3D9; border-radius: 18px; padding: 16px 16px 18px; text-decoration: none;">
              <p style="font-family: 'Playfair Display', Georgia, serif; font-size: 18px; font-weight: 600; color: #1C2456; line-height: 1.15; margin-bottom: 8px;">About</p>
              <p style="font-family: Inter, sans-serif; font-size: 13px; font-weight: 300; color: #45465E; line-height: 1.65;">Read more about Sabiha Iftakhar, RCIC, and the approach behind the practice.</p>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  @media (max-width: 768px) {
    .not-found-links {
      grid-template-columns: 1fr !important;
    }

    .not-found-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .not-found-actions a {
      width: 100%;
    }
  }
</style>
