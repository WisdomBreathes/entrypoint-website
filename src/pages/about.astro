---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;

const credentials = [
  {
    label: 'RCIC Registration',
    detail: 'Registered Canadian Immigration Consultant — licensed to provide immigration advice and representation in Canada.',
    icon: 'shield',
  },
  {
    label: 'CICC Licensee in Good Standing',
    detail: 'Active licensee of the College of Immigration and Citizenship Consultants (CICC), meeting all continuing education requirements.',
    icon: 'award',
  },
  {
    label: 'IRCC Authorized Representative',
    detail: 'Fully authorized to represent clients before Immigration, Refugees and Citizenship Canada across all application types.',
    icon: 'badge',
  },
  {
    label: '15+ Years of Experience',
    detail: 'Over fifteen years guiding clients through Canada\'s immigration system, from study permits to citizenship ceremonies.',
    icon: 'clock',
  },
];

const values = [
  {
    title: 'Honesty over promises',
    body: 'Sabiha will never tell you what you want to hear if it isn\'t true. You\'ll receive an honest assessment of your chances, your risks, and your options — every time.',
  },
  {
    title: 'No case is routine',
    body: 'Every client\'s situation is different. Sabiha treats each file with fresh eyes and individual attention, never relying on a one-size-fits-all approach.',
  },
  {
    title: 'Regulated. Accountable. Protected.',
    body: 'As a regulated consultant, Sabiha operates under a strict code of professional conduct. You have formal recourse and protection that unlicensed consultants cannot offer.',
  },
  {
    title: 'You\'re not alone in this',
    body: 'Immigration is stressful and personal. Sabiha stays with you throughout the entire process — answering questions, managing updates, and advocating on your behalf.',
  },
];
---

<Layout title="About Sabiha Iftakhar — Entrypoint Canada">
  <Navbar />
  <main id="main-content">

    <!-- Page hero -->
    <section style="position: relative; overflow: hidden; background: #3D1215; padding: 72px 0 64px; min-height: 420px; display: flex; align-items: center;">
      <div style="position: absolute; inset: 0; z-index: 0;">
        <img
          src={`${base}images/leonard-laub-X8Dc_8rXZHA-unsplash.jpg`}
      loading="eager"
      fetchpriority="high"
          alt=""
          style="width: 100%; height: 100%; object-fit: cover; object-position: center center;"
        />
        <div style="position: absolute; inset: 0; background: rgba(10,5,5,0.65);"></div>
      </div>
      <div class="page-hero-inner" style="position: relative; z-index: 1;">
        <a href={base} style="display: inline-flex; align-items: center; gap: 6px; font-family: Inter, sans-serif; font-size: 13px; color: rgba(255,255,255,0.6); text-decoration: none; margin-bottom: 24px; transition: color 0.15s;"
           onmouseover="this.style.color='rgba(255,255,255,0.9)'" onmouseout="this.style.color='rgba(255,255,255,0.6)'">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
          Back to home
        </a>
        <p style="font-family: Inter, sans-serif; font-size: 10px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: #C4973A; margin-bottom: 12px;">
          Your consultant
        </p>
        <h1 style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(30px, 4vw, 42px); font-weight: 700; color: #ffffff; line-height: 1.1; margin-bottom: 16px;">
          Sabiha Iftakhar
        </h1>
        <p style="font-family: 'Playfair Display', Georgia, serif; font-size: 20px; font-weight: 400; font-style: italic; color: rgba(255,255,255,0.75); margin-bottom: 24px;">
          Registered Canadian Immigration Consultant (RCIC)
        </p>
        <p style="font-family: Inter, sans-serif; font-size: 15px; font-weight: 300; color: rgba(255,255,255,0.72); max-width: 560px; line-height: 1.7;">
          Based in Cambridge, Ontario. 15+ years of experience. 500+ clients guided to their Canadian future.
        </p>
      </div>
    </section>

    <!-- Bio section -->
    <section style="background: #FAF7F2;" aria-labelledby="bio-heading">
      <div class="section-container">
        <div style="display: grid; grid-template-columns: 1fr; gap: 56px;" class="about-page-grid">

          <!-- Left: Avatar + credential badges -->
          <div style="display: flex; flex-direction: column; gap: 24px; align-items: flex-start;">

            <!-- Avatar placeholder -->
            <!-- TODO: Replace with real photo when provided -->
            <div class="about-card" style="width: 100%; max-width: 320px; aspect-ratio: 3/4; background: #3D1215; border-radius: 12px; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden;">
              <div style="text-align: center;">
                <span style="font-family: 'Playfair Display', Georgia, serif; font-size: 64px; font-weight: 600; color: rgba(255,255,255,0.9);">SI</span>
                <p style="font-family: Inter, sans-serif; font-size: 12px; color: rgba(255,255,255,0.4); margin-top: 8px;">Photo coming soon</p>
              </div>
              <div style="position: absolute; bottom: 0; left: 0; right: 0; background: linear-gradient(transparent, rgba(45,8,10,0.6)); padding: 24px 20px 20px;">
                <p style="font-family: 'Playfair Display', Georgia, serif; font-size: 18px; font-weight: 600; color: white; margin-bottom: 2px;">Sabiha Iftakhar</p>
                <p style="font-family: Inter, sans-serif; font-size: 12px; color: rgba(255,255,255,0.7);">RCIC · CICC Licensee</p>
              </div>
            </div>

            <!-- Quick facts -->
            <div style="width: 100%; max-width: 320px; background: white; border: 1px solid #E8E3D9; border-radius: 10px; padding: 24px; display: flex; flex-direction: column; gap: 14px;">
              <div style="display: flex; align-items: center; gap: 10px;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#C4973A" stroke-width="1.5" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <span style="font-family: Inter, sans-serif; font-size: 13px; color: #5C5C7A;">Cambridge, Ontario</span>
              </div>
              <div style="display: flex; align-items: center; gap: 10px;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#C4973A" stroke-width="1.5" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <a href="mailto:info@entrypointcanada.com" style="font-family: Inter, sans-serif; font-size: 13px; color: #5C5C7A; text-decoration: none; transition: color 0.15s;" onmouseover="this.style.color='#3D1215'" onmouseout="this.style.color='#5C5C7A'">info@entrypointcanada.com</a>
              </div>
              <div style="display: flex; align-items: center; gap: 10px;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#C4973A" stroke-width="1.5" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.35 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 6 6l.94-1.94a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21.5 15z"/></svg>
                <a href="tel:6479060011" style="font-family: Inter, sans-serif; font-size: 13px; color: #5C5C7A; text-decoration: none; transition: color 0.15s;" onmouseover="this.style.color='#3D1215'" onmouseout="this.style.color='#5C5C7A'">647-906-0011</a>
              </div>
              <div style="height: 1px; background: #E8E3D9;"></div>
              <a href={`${base}contact`} class="btn-burgundy" style="justify-content: center;">Book a consultation</a>
            </div>

          </div>

          <!-- Right: Full bio -->
          <div style="display: flex; flex-direction: column; gap: 28px;">

            <div>
              <p style="font-family: Inter, sans-serif; font-size: 10px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: #8B1A1A; margin-bottom: 8px;">
                Her story
              </p>
              <h2 id="bio-heading" style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(24px, 2.5vw, 32px); font-weight: 600; color: #1A1A2E; line-height: 1.25; margin-bottom: 24px;">
                Guided by expertise.<br>Driven by your success.
              </h2>
            </div>

            <div style="display: flex; flex-direction: column; gap: 18px;">
              <p style="font-family: Inter, sans-serif; font-size: 15px; font-weight: 300; color: #3D3D5C; line-height: 1.8;">
                Sabiha Iftakhar is a Registered Canadian Immigration Consultant (RCIC) with over 15 years of experience helping individuals and families navigate Canada's complex immigration system. She is a member in good standing with the College of Immigration and Citizenship Consultants (CICC) and is fully authorized to represent clients before Immigration, Refugees and Citizenship Canada (IRCC).
              </p>
              <p style="font-family: Inter, sans-serif; font-size: 15px; font-weight: 300; color: #3D3D5C; line-height: 1.8;">
                Based in Cambridge, Ontario, Sabiha has worked with clients from every corner of the world — from first-time Express Entry applicants to families navigating the spousal sponsorship process, to individuals seeking refugee protection in difficult circumstances. She has seen nearly every variation of immigration challenge Canada presents.
              </p>
              <p style="font-family: Inter, sans-serif; font-size: 15px; font-weight: 300; color: #3D3D5C; line-height: 1.8;">
                Her approach has always been the same: be honest, be thorough, and be present. She doesn't make promises she can't keep, and she doesn't take on cases she can't serve well. What she does do is commit — fully — to every client who trusts her with their Canadian future.
              </p>
              <p style="font-family: Inter, sans-serif; font-size: 15px; font-weight: 300; color: #3D3D5C; line-height: 1.8;">
                Over 500 clients have successfully navigated Canada's immigration pathways under her guidance. Many have returned for subsequent applications — study permits followed by work permits, permanent residency followed by citizenship. They come back because they trust her. That trust is something she takes seriously every single day.
              </p>
            </div>

            <!-- Trust facts -->
            <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 8px;">
              <div class="stat-item" style="background: white; border-left: 3px solid #8B1A1A; border-radius: 10px; padding: 16px 20px;">
                <p style="font-family: 'Playfair Display', Georgia, serif; font-size: 22px; font-weight: 700; color: #1C2456; line-height: 1.1; margin-bottom: 4px;">Licensed RCIC</p>
                <p style="font-family: Inter, sans-serif; font-size: 12px; font-weight: 300; color: #5C5C7A;">Member in good standing with the CICC</p>
              </div>
              <div class="stat-item" style="background: white; border-left: 3px solid #8B1A1A; border-radius: 10px; padding: 16px 20px;">
                <p style="font-family: 'Playfair Display', Georgia, serif; font-size: 22px; font-weight: 700; color: #1C2456; line-height: 1.1; margin-bottom: 4px;">English, Urdu, Punjabi, Hindi</p>
                <p style="font-family: Inter, sans-serif; font-size: 12px; font-weight: 300; color: #5C5C7A;">Consultations available in multiple languages</p>
              </div>
              <div class="stat-item" style="background: white; border-left: 3px solid #8B1A1A; border-radius: 10px; padding: 16px 20px;">
                <p style="font-family: 'Playfair Display', Georgia, serif; font-size: 22px; font-weight: 700; color: #1C2456; line-height: 1.1; margin-bottom: 4px;">Free 30-minute consultation</p>
                <p style="font-family: Inter, sans-serif; font-size: 12px; font-weight: 300; color: #5C5C7A;">Initial review before formal representation begins</p>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- Credentials section -->
    <section style="background: #ffffff;" aria-labelledby="credentials-heading">
      <div class="section-container">
        <p style="font-family: Inter, sans-serif; font-size: 10px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: #8B1A1A; margin-bottom: 8px;">
          Qualifications
        </p>
        <h2 id="credentials-heading" style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(24px, 2.5vw, 32px); font-weight: 600; color: #1A1A2E; line-height: 1.25; margin-bottom: 40px; max-width: 480px;">
          Regulated, authorized, and accountable.
        </h2>

        <!-- RCIC Licence placeholder -->
        <div style="background: #F4F1EB; border: 1px solid #E8E3D9; border-left: 4px solid #C4973A; border-radius: 10px; padding: 28px 32px; margin-bottom: 40px; display: flex; align-items: flex-start; gap: 20px;">
          <div style="width: 48px; height: 48px; border-radius: 50%; background: rgba(196,151,58,0.15); border: 2px solid rgba(196,151,58,0.3); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C4973A" stroke-width="1.5" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
          </div>
          <div>
            <p style="font-family: Inter, sans-serif; font-size: 13px; font-weight: 600; color: #C4973A; letter-spacing: 0.04em; text-transform: uppercase; margin-bottom: 4px;">RCIC Licence</p>
            <p style="font-family: 'Playfair Display', Georgia, serif; font-size: 20px; font-weight: 600; color: #1A1A2E; margin-bottom: 6px;">Sabiha Iftakhar — RCIC R412247</p>
            <p style="font-family: Inter, sans-serif; font-size: 13px; font-weight: 300; color: #5C5C7A;">
              CICC Registration Number: R412247 · Status: Active Member in Good Standing
            </p>
          </div>
        </div>

        <!-- Verify Licence block -->
        <div style="background: #F4F1EB; border: 1px solid #E8E3D9; border-left: 4px solid #C4973A; border-radius: 10px; padding: 28px 32px; margin-bottom: 40px; display: flex; align-items: flex-start; gap: 20px;">
          <div style="width: 48px; height: 48px; border-radius: 50%; background: rgba(196,151,58,0.15); border: 2px solid rgba(196,151,58,0.3); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C4973A" stroke-width="1.5" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </div>
          <div>
            <p style="font-family: Inter, sans-serif; font-size: 13px; font-weight: 600; color: #C4973A; letter-spacing: 0.04em; text-transform: uppercase; margin-bottom: 4px;">Verify Licence</p>
            <p style="font-family: 'Playfair Display', Georgia, serif; font-size: 18px; font-weight: 600; color: #1A1A2E; margin-bottom: 6px;">Confirm Standing on the Official Public Register</p>
            <p style="font-family: Inter, sans-serif; font-size: 13px; font-weight: 300; color: #5C5C7A; margin-bottom: 12px; line-height: 1.65;">
              Sabiha Iftakhar is a licensed RCIC in good standing. You can confirm her standing directly on the official public register.
            </p>
            <a
              href="https://register.college-ic.ca/"
              target="_blank"
              rel="noopener noreferrer"
              style="font-family: Inter, sans-serif; font-size: 13px; font-weight: 500; color: #C4973A; text-decoration: underline; transition: color 0.15s;"
              onmouseover="this.style.color='#8B1A1A'" onmouseout="this.style.color='#C4973A'"
            >
              Verify RCIC Licence on the Official CICC Public Register →
            </a>
          </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr; gap: 16px;" class="cred-grid">
          {credentials.map((cred) => (
            <div style="background: #FAF7F2; border: 1px solid #E8E3D9; border-radius: 10px; padding: 24px; display: flex; gap: 16px; align-items: flex-start;">
              <div style="width: 40px; height: 40px; border-radius: 8px; background: #3D1215; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                {cred.icon === 'shield' && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>}
                {cred.icon === 'award' && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>}
                {cred.icon === 'badge' && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>}
                {cred.icon === 'clock' && <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>}
              </div>
              <div>
                <p style="font-family: Inter, sans-serif; font-size: 14px; font-weight: 600; color: #1A1A2E; margin-bottom: 4px;">{cred.label}</p>
                <p style="font-family: Inter, sans-serif; font-size: 13px; font-weight: 300; color: #5C5C7A; line-height: 1.6;">{cred.detail}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Philosophy section -->
    <section style="background: #F4F1EB;" aria-labelledby="philosophy-heading">
      <div class="section-container">
        <p style="font-family: Inter, sans-serif; font-size: 10px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: #8B1A1A; margin-bottom: 8px;">
          How she works
        </p>
        <h2 id="philosophy-heading" style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(24px, 2.5vw, 32px); font-weight: 600; color: #1A1A2E; line-height: 1.25; margin-bottom: 40px; max-width: 480px;">
          The Entrypoint approach.
        </h2>
        <div style="display: grid; grid-template-columns: 1fr; gap: 20px;" class="values-grid">
          {values.map((v, i) => (
            <div style="background: white; border-radius: 10px; padding: 28px 32px; position: relative; overflow: hidden;">
              <span style="position: absolute; top: 16px; right: 20px; font-family: 'Playfair Display', Georgia, serif; font-size: 48px; font-weight: 700; color: #F4F1EB; line-height: 1; user-select: none;" aria-hidden="true">
                0{i + 1}
              </span>
              <h3 style="font-family: 'Playfair Display', Georgia, serif; font-size: 20px; font-weight: 600; color: #1A1A2E; margin-bottom: 10px; position: relative;">{v.title}</h3>
              <p style="font-family: Inter, sans-serif; font-size: 14px; font-weight: 300; color: #5C5C7A; line-height: 1.7; position: relative;">{v.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section style="background: #3D1215;">
      <div class="section-container" style="text-align: center;">
        <p style="font-family: Inter, sans-serif; font-size: 10px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: #C4973A; margin-bottom: 12px;">
          Ready to begin?
        </p>
        <h2 style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(24px, 2.5vw, 32px); font-weight: 600; color: white; line-height: 1.25; margin-bottom: 12px; max-width: 460px; margin-left: auto; margin-right: auto;">
          Book a free consultation with Sabiha.
        </h2>
        <p style="font-family: Inter, sans-serif; font-size: 15px; font-weight: 300; color: rgba(255,255,255,0.75); margin-bottom: 32px; max-width: 400px; margin-left: auto; margin-right: auto; line-height: 1.65;">
          30 minutes. No pressure. Just honest answers about your situation and the best path forward.
        </p>
        <div style="display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 12px;">
          <a href={`${base}contact`} class="btn-gold">Book a free consultation</a>
          <a href="tel:6479060011" class="btn-crimson">Call 647-906-0011</a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  @media (min-width: 900px) {
    .about-page-grid {
      grid-template-columns: 340px 1fr !important;
    }
  }
  @media (min-width: 640px) {
    .cred-grid {
      grid-template-columns: 1fr 1fr !important;
    }
    .values-grid {
      grid-template-columns: 1fr 1fr !important;
    }
  }

  @media (max-width: 768px) {
    /* Hero heading */
    .page-hero-inner h1 { font-size: 32px !important; }

    /* Stats row on about page — shrink numbers to fit 3-col */
    .about-page-grid + div [style*="grid-template-columns: repeat(3, 1fr)"] {
      gap: 8px;
    }
    /* Target the inline-styled stats grid */
    div[style*="repeat(3, 1fr)"] > div p:first-child {
      font-size: 22px !important;
    }
    div[style*="repeat(3, 1fr)"] > div {
      padding: 10px 10px !important;
    }

    /* Avatar card max-width: remove on mobile to fill width */
    div[style*="max-width: 320px"] {
      max-width: 100% !important;
    }
  }
</style>
