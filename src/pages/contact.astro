---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;

const services = [
  'Permanent Residency (Express Entry / PNP)',
  'Family Sponsorship',
  'Study Permit',
  'Work Permit / LMIA',
  'Post-Graduation Work Permit (PGWP)',
  'Citizenship Application',
  'Refugee / Humanitarian',
  'Other / Not sure yet',
];
---

<Layout
  title="Book an Immigration Consultation in Cambridge & Kitchener-Waterloo"
  description="Book an immigration consultation with Entrypoint Canada. Applicants in Cambridge, Kitchener, Waterloo, and nearby communities can share their situation and receive a professional assessment of the pathways that may apply."
  heroImage="contact"
>
  <Navbar />
  <main id="main-content">

    <!-- Page hero -->
    <section style="position: relative; overflow: hidden; background: #3D1215; padding: 72px 0 64px; min-height: 420px; display: flex; align-items: center;">
      <div style="position: absolute; inset: 0; z-index: 0;">
        <picture>
          <source
            type="image/webp"
            srcset={`${base}images/john-lee-oMneOBYhJxY-unsplash-800w.webp 800w, ${base}images/john-lee-oMneOBYhJxY-unsplash-1400w.webp 1400w`}
            sizes="100vw"
          />
          <img
            src={`${base}images/john-lee-oMneOBYhJxY-unsplash-1400w.webp`}
            loading="eager"
            fetchpriority="high"
            decoding="sync"
            alt=""
            width="1400"
            height="1002"
            style="width: 100%; height: 100%; object-fit: cover; object-position: center 40%;"
          />
        </picture>
        <div style="position: absolute; inset: 0; background: rgba(10,5,5,0.65);"></div>
      </div>
      <div class="page-hero-inner page-hero-copy" style="position: relative; z-index: 1;">
        <a href={base} class="page-back-link" style="display: inline-flex; align-items: center; gap: 6px; font-family: Inter, sans-serif; font-size: 13px; color: rgba(255,255,255,0.6); text-decoration: none; margin-bottom: 24px; transition: color 0.15s;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
          Back to home
        </a>
        <p style="font-family: Inter, sans-serif; font-size: 10px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: #C4973A; margin-bottom: 12px;">
          Get in touch
        </p>
        <h1 style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(30px, 4vw, 42px); font-weight: 700; color: #ffffff; line-height: 1.1; margin-bottom: 16px;">
          Book your free consultation.
        </h1>
        <p style="font-family: Inter, sans-serif; font-size: 16px; font-weight: 300; color: rgba(255,255,255,0.72); max-width: 520px; line-height: 1.7;">
          Share a few details about your matter and receive an initial professional assessment of the options that may be available to you.
        </p>
      </div>
    </section>

    <!-- Main content: form + info -->
    <section style="background: #FAF7F2;" aria-labelledby="contact-heading">
      <div class="section-container">
        <div style="display: grid; grid-template-columns: 1fr; gap: 56px;" class="contact-grid">

          <!-- Left: Form -->
          <div>
            <h2 id="contact-heading" style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(22px, 2.5vw, 30px); font-weight: 600; color: #1A1A2E; margin-bottom: 8px;">
              Send us a message
            </h2>
            <p style="font-family: Inter, sans-serif; font-size: 14px; font-weight: 300; color: #45465E; margin-bottom: 32px; line-height: 1.65;">
              Provide a short overview of your situation and we will respond within one business day.
            </p>

            <!--
              TODO: Replace action URL with real Formspree endpoint.
              Sign up at https://formspree.io, create a form, and paste your endpoint here.
              Example: action="https://formspree.io/f/YOUR_FORM_ID"
            -->
            <form
              action="https://formspree.io/f/xpqogqow"
              method="POST"
              id="contact-form"
              style="display: flex; flex-direction: column; gap: 20px;"
            >
              <input type="hidden" name="_subject" value="New consultation request — Entrypoint Canada" />
              <input type="hidden" name="_next" value={`https://entrypointcanada.com${base}thank-you`} />
              <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" aria-hidden="true" style="position: absolute; left: -9999px; opacity: 0; pointer-events: none;" />

              <!-- Name + Email -->
              <div style="display: grid; grid-template-columns: 1fr; gap: 20px;" class="form-row">
                <div style="display: flex; flex-direction: column; gap: 6px;">
                  <label for="name" style="font-family: Inter, sans-serif; font-size: 13px; font-weight: 500; color: #1A1A2E;">
                    Full name <span style="color: #8B1A1A;" aria-hidden="true">*</span>
                  </label>
                  <input
                    type="text"
                    id="name"
                    name="full_name"
                    required
                    autocomplete="name"
                    placeholder="Your full name"
                    style="font-family: Inter, sans-serif; font-size: 14px; color: #1A1A2E; background: white; border: 1px solid #D9D2C5; border-radius: 8px; padding: 12px 16px; width: 100%; outline: none; transition: border-color 0.15s;"
                    onfocus="this.style.borderColor='#3D1215'" onblur="this.style.borderColor='#D9D2C5'"
                  />
                </div>
                <div style="display: flex; flex-direction: column; gap: 6px;">
                  <label for="email" style="font-family: Inter, sans-serif; font-size: 13px; font-weight: 500; color: #1A1A2E;">
                    Email address <span style="color: #8B1A1A;" aria-hidden="true">*</span>
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    autocomplete="email"
                    placeholder="you@example.com"
                    style="font-family: Inter, sans-serif; font-size: 14px; color: #1A1A2E; background: white; border: 1px solid #D9D2C5; border-radius: 8px; padding: 12px 16px; width: 100%; outline: none; transition: border-color 0.15s;"
                    onfocus="this.style.borderColor='#3D1215'" onblur="this.style.borderColor='#D9D2C5'"
                  />
                </div>
              </div>

              <!-- Phone -->
              <div style="display: flex; flex-direction: column; gap: 6px;">
                <label for="phone" style="font-family: Inter, sans-serif; font-size: 13px; font-weight: 500; color: #1A1A2E;">
                  Phone number <span style="font-size: 12px; font-weight: 300; color: #45465E;">(optional)</span>
                </label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  autocomplete="tel"
                  inputmode="tel"
                  maxlength="20"
                  pattern="^[0-9+() .-]{7,20}$"
                  placeholder="+1 (___) ___-____"
                  style="font-family: Inter, sans-serif; font-size: 14px; color: #1A1A2E; background: white; border: 1px solid #D9D2C5; border-radius: 8px; padding: 12px 16px; width: 100%; outline: none; transition: border-color 0.15s;"
                  onfocus="this.style.borderColor='#3D1215'" onblur="this.style.borderColor='#D9D2C5'"
                />
              </div>

              <!-- Service dropdown -->
              <div style="display: flex; flex-direction: column; gap: 6px;">
                <label for="service" style="font-family: Inter, sans-serif; font-size: 13px; font-weight: 500; color: #1A1A2E;">
                  Service you're interested in <span style="color: #8B1A1A;" aria-hidden="true">*</span>
                </label>
                <div style="position: relative;">
                  <select
                    id="service"
                    name="service"
                    required
                    style="font-family: Inter, sans-serif; font-size: 14px; color: #1A1A2E; background: white; border: 1px solid #D9D2C5; border-radius: 8px; padding: 12px 40px 12px 16px; width: 100%; outline: none; appearance: none; -webkit-appearance: none; cursor: pointer; transition: border-color 0.15s;"
                    onfocus="this.style.borderColor='#3D1215'" onblur="this.style.borderColor='#D9D2C5'"
                  >
                    <option value="" disabled selected style="color: #45465E;">Select a service…</option>
                    {services.map((s) => (
                      <option value={s}>{s}</option>
                    ))}
                  </select>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#45465E" stroke-width="1.5"
                       style="position: absolute; right: 14px; top: 50%; transform: translateY(-50%); pointer-events: none;" aria-hidden="true">
                    <polyline points="6 9 12 15 18 9"/>
                  </svg>
                </div>
              </div>

              <!-- Message -->
              <div style="display: flex; flex-direction: column; gap: 6px;">
                <label for="message" style="font-family: Inter, sans-serif; font-size: 13px; font-weight: 500; color: #1A1A2E;">
                  Your message <span style="color: #8B1A1A;" aria-hidden="true">*</span>
                </label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="5"
                  maxlength="2000"
                  placeholder="Tell us briefly about your situation — where you're from, your current status in Canada, and what you're hoping to achieve."
                  style="font-family: Inter, sans-serif; font-size: 14px; color: #1A1A2E; background: white; border: 1px solid #D9D2C5; border-radius: 8px; padding: 12px 16px; width: 100%; outline: none; resize: vertical; line-height: 1.6; transition: border-color 0.15s;"
                  onfocus="this.style.borderColor='#3D1215'" onblur="this.style.borderColor='#D9D2C5'"
                ></textarea>
                <p style="font-family: Inter, sans-serif; font-size: 12px; font-weight: 300; color: #45465E;">
                  Your information is kept strictly confidential and never shared with third parties.
                </p>
                <p id="contact-form-error" style="display: none; font-family: Inter, sans-serif; font-size: 12px; font-weight: 500; color: #8B1A1A; line-height: 1.6;"></p>
              </div>

              <!-- Submit -->
              <div>
                <button type="submit" class="btn-burgundy" style="width: 100%; justify-content: center; padding: 14px 24px; font-size: 15px;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <line x1="22" y1="2" x2="11" y2="13"/>
                    <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                  </svg>
                  Book Free Consultation
                </button>
                <p style="font-family: Inter, sans-serif; font-size: 12px; font-weight: 300; color: #45465E; text-align: center; margin-top: 12px;">
                  We respond within one business day. Fields marked <span style="color: #8B1A1A;">*</span> are required.
                </p>
                <p style="font-family: Inter, sans-serif; font-size: 11px; font-weight: 300; color: #9C9C9C; text-align: center; margin-top: 10px; line-height: 1.65;">
                  Submission of this form does not create a consultant-client relationship. Representation begins only after a signed retainer agreement. This form is processed by Formspree, a third-party service.
                </p>
              </div>

            </form>
          </div>

          <!-- Right: Contact info -->
          <div style="display: flex; flex-direction: column; gap: 32px;">

            <!-- Direct contact -->
            <div>
              <h2 style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(22px, 2.5vw, 28px); font-weight: 700; color: #1A1A2E; margin-bottom: 24px;">
                Or reach us directly
              </h2>

              <div style="display: flex; flex-direction: column; gap: 20px;">

                <a href="tel:6479060011" class="contact-direct-card" style="display: flex; align-items: flex-start; gap: 16px; background: white; border: 1px solid #E8E3D9; border-radius: 10px; padding: 20px 24px; text-decoration: none; transition: box-shadow 0.15s;">
                  <div style="width: 40px; height: 40px; border-radius: 8px; background: #3D1215; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.35 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 6 6l.94-1.94a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21.5 15z"/></svg>
                  </div>
                  <div>
                    <p style="font-family: Inter, sans-serif; font-size: 12px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: #45465E; margin-bottom: 4px;">Phone</p>
                    <p style="font-family: 'Playfair Display', Georgia, serif; font-size: 20px; font-weight: 600; color: #1A1A2E; margin-bottom: 2px;">647-906-0011</p>
                    <p style="font-family: Inter, sans-serif; font-size: 13px; font-weight: 300; color: #45465E;">Mon–Fri, 9am–6pm ET</p>
                  </div>
                </a>

                <a href="mailto:info@entrypointcanada.com" class="contact-direct-card" style="display: flex; align-items: flex-start; gap: 16px; background: white; border: 1px solid #E8E3D9; border-radius: 10px; padding: 20px 24px; text-decoration: none; transition: box-shadow 0.15s;">
                  <div style="width: 40px; height: 40px; border-radius: 8px; background: #3D1215; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                  </div>
                  <div>
                    <p style="font-family: Inter, sans-serif; font-size: 12px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: #45465E; margin-bottom: 4px;">Email</p>
                    <p style="font-family: 'Playfair Display', Georgia, serif; font-size: 18px; font-weight: 600; color: #1A1A2E; margin-bottom: 2px;">info@entrypointcanada.com</p>
                    <p style="font-family: Inter, sans-serif; font-size: 13px; font-weight: 300; color: #45465E;">We respond within one business day</p>
                  </div>
                </a>

                <div style="display: flex; align-items: flex-start; gap: 16px; background: white; border: 1px solid #E8E3D9; border-radius: 10px; padding: 20px 24px;">
                  <div style="width: 40px; height: 40px; border-radius: 8px; background: #3D1215; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  </div>
                  <div>
                    <p style="font-family: Inter, sans-serif; font-size: 12px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: #45465E; margin-bottom: 4px;">Office</p>
                    <p style="font-family: 'Playfair Display', Georgia, serif; font-size: 18px; font-weight: 600; color: #1A1A2E; margin-bottom: 2px;">Cambridge, Ontario</p>
                    <p style="font-family: Inter, sans-serif; font-size: 13px; font-weight: 300; color: #45465E; line-height: 1.6;">37 Faith St<br>Cambridge, ON</p>
                  </div>
                </div>

              </div>
            </div>

            <!-- What to expect -->
            <div style="background: #3D1215; border-radius: 12px; padding: 28px 32px;">
              <h3 style="font-family: 'Playfair Display', Georgia, serif; font-size: 20px; font-weight: 600; color: white; margin-bottom: 20px;">
                What to expect
              </h3>
              <div style="display: flex; flex-direction: column; gap: 16px;">
                {[
                  { step: '01', text: 'You send a message or call — Sabiha or her team responds within one business day.' },
                  { step: '02', text: 'We schedule a free 30-minute consultation at a time that works for you.' },
                  { step: '03', text: 'Sabiha reviews your situation and identifies the right pathway.' },
                  { step: '04', text: 'If we\'re a good fit, we outline a clear plan and next steps together.' },
                ].map((item) => (
                  <div style="display: flex; align-items: flex-start; gap: 14px;">
                    <span style="font-family: 'Playfair Display', Georgia, serif; font-size: 22px; font-weight: 700; color: rgba(196,151,58,0.5); line-height: 1; flex-shrink: 0; width: 28px;">{item.step}</span>
                    <p style="font-family: Inter, sans-serif; font-size: 13px; font-weight: 300; color: rgba(255,255,255,0.8); line-height: 1.6;">{item.text}</p>
                  </div>
                ))}
              </div>
            </div>

            <!-- Privacy note -->
            <div id="privacy" style="background: #F4F1EB; border: 1px solid #E8E3D9; border-radius: 10px; padding: 20px 24px;">
              <p style="font-family: Inter, sans-serif; font-size: 12px; font-weight: 600; color: #1A1A2E; margin-bottom: 6px;">Privacy & Confidentiality</p>
              <p style="font-family: Inter, sans-serif; font-size: 12px; font-weight: 300; color: #45465E; line-height: 1.65;">
                All information you share with Entrypoint Canada is kept strictly confidential. As a regulated RCIC, Sabiha operates under the CICC Code of Professional Conduct, which includes binding confidentiality obligations. Your information is never sold, shared, or disclosed to third parties without your express consent.
              </p>
            </div>

          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  @media (min-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr 420px !important;
    }
  }
  @media (min-width: 640px) {
    .form-row {
      grid-template-columns: 1fr 1fr !important;
    }
  }

  .page-back-link:hover {
    color: rgba(255,255,255,0.9);
  }

  .contact-direct-card:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,0.07);
  }
</style>

<style>
  @media (max-width: 768px) {
    /* Hero heading */
    .page-hero-inner h1 { font-size: 32px !important; }

    /* Prevent iOS zoom on form inputs */
    input, textarea, select { font-size: 16px !important; }
  }
</style>

<script>
  const contactForm = document.getElementById('contact-form');
  const phoneInput = document.getElementById('phone');
  const messageInput = document.getElementById('message');
  const formError = document.getElementById('contact-form-error');
  const riskyLinkPattern = /(https?:\/\/|www\.|(?:[a-z0-9-]+\.)+(?:com|net|org|io|co|ca|ru|xyz|info|ly)\b|javascript:|<script)/i;

  function showFormError(message) {
    formError.textContent = message;
    formError.style.display = 'block';
  }

  function clearFormError() {
    formError.textContent = '';
    formError.style.display = 'none';
  }

  if (phoneInput) {
    phoneInput.addEventListener('input', () => {
      phoneInput.value = phoneInput.value.replace(/[^0-9+() .-]/g, '').slice(0, 20);
    });
  }

  if (messageInput) {
    messageInput.addEventListener('input', clearFormError);
  }

  if (contactForm) {
    contactForm.addEventListener('submit', (event) => {
      clearFormError();

      if (phoneInput && phoneInput.value && !phoneInput.checkValidity()) {
        event.preventDefault();
        showFormError('Please enter a valid phone number using digits and common phone symbols only.');
        phoneInput.focus();
        return;
      }

      if (messageInput && riskyLinkPattern.test(messageInput.value)) {
        event.preventDefault();
        showFormError('Please remove links or code-like content from the message and describe your situation in plain text.');
        messageInput.focus();
      }
    });
  }
</script>
