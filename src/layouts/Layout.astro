---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Entrypoint Canada Immigration Services — Regulated Canadian Immigration Consultant (RCIC) in Cambridge, ON. 500+ clients served. Book a free consultation today.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Entrypoint Canada" />

    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preload hero images for LCP performance -->
    <link rel="preload" as="image" href="/images/ampersand-studios-pp_oXEb2H48-unsplash.jpg" />
    <link rel="preload" as="image" href="/images/leonard-laub-X8Dc_8rXZHA-unsplash.jpg" />
    <link rel="preload" as="image" href="/images/ashley-ross-qZEeC8t0UKE-unsplash.jpg" />
    <link rel="preload" as="image" href="/images/john-lee-oMneOBYhJxY-unsplash.jpg" />
    <link rel="preload" as="image" href="/images/cole-keister-rydTSO7xB5A-unsplash.jpg" />

    <!-- View transitions -->
    <style>
      @view-transition { navigation: auto; }
      ::view-transition-old(root) { animation: 0.2s ease both vt-fade-out; }
      ::view-transition-new(root) { animation: 0.2s ease both vt-fade-in; }
      @keyframes vt-fade-out { from { opacity: 1; } to { opacity: 0; } }
      @keyframes vt-fade-in  { from { opacity: 0; } to { opacity: 1; } }
    </style>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <title>{title}</title>
  </head>
  <body>
    <!-- Skip to main content (WCAG) -->
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <slot />
  </body>
</html>

<style is:global>
  /* ── Reset & base ── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    scroll-behavior: smooth;
    background: #FAF7F2;
  }

  body {
    font-family: 'Inter', system-ui, sans-serif;
    color: #1A1A2E;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  a { text-decoration: none; }

  /* ── Skip link ── */
  .skip-link {
    position: absolute;
    top: -48px;
    left: 16px;
    z-index: 1000;
    background: #3D1215;
    color: white;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 600;
    padding: 8px 16px;
    border-radius: 6px;
    transition: top 0.15s;
  }
  .skip-link:focus { top: 8px; }

  /* ── Focus visible ── */
  :focus-visible {
    outline: 2px solid #C4973A;
    outline-offset: 2px;
  }

  /* ── Buttons ── */
  .btn-gold {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #C4973A;
    color: #1A0F00;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 600;
    padding: 14px 28px;
    border-radius: 7px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .btn-gold:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 8px 24px rgba(196, 151, 58, 0.35);
  }
  .btn-gold:active { transform: scale(0.98); }

  .btn-burgundy {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #3D1215;
    color: white;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 600;
    padding: 14px 24px;
    border-radius: 7px;
    border: 1px solid rgba(255,255,255,0.15);
    cursor: pointer;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }
  .btn-burgundy:hover {
    transform: translateY(-2px);
    background: #2C0D0F;
    box-shadow: 0 8px 24px rgba(61, 18, 21, 0.3);
  }
  .btn-burgundy:active { transform: scale(0.98); }

  .btn-crimson {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #8B1A1A;
    color: white;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 600;
    padding: 14px 24px;
    border-radius: 7px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: transform 0.2s ease, background 0.2s ease;
  }
  .btn-crimson:hover {
    background: #A0272A;
    transform: translateY(-1px);
  }
  .btn-crimson:active { transform: scale(0.98); }

  /* ── Nav links ── */
  .nav-link {
    position: relative;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #1A1A2E;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1.5px;
    background: #3D1215;
    transition: width 0.25s ease;
  }
  .nav-link:hover { color: #3D1215; }
  .nav-link:hover::after { width: 100%; }

  /* ── Service cards ── */
  .service-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    background: #F4F1EB;
    border: 1px solid #E8E3D9;
    border-radius: 10px;
    padding: 24px;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .service-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(61, 18, 21, 0.12);
  }
  .service-card:focus-visible {
    outline: 2px solid #1C2456;
    outline-offset: 2px;
  }

  /* ── Testimonial cards ── */
  .testimonial-card {
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .testimonial-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(61, 18, 21, 0.1);
  }

  /* ── About card ── */
  .about-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .about-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 48px rgba(61, 18, 21, 0.2);
  }

  /* ── Stat items ── */
  .stat-item {
    transition: transform 0.2s ease;
    cursor: default;
  }
  .stat-item:hover { transform: scale(1.05); }

  /* ── Process circles ── */
  .process-circle {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .process-circle:hover {
    transform: scale(1.1);
    box-shadow: 0 8px 24px rgba(61, 18, 21, 0.25);
  }

  /* ── Credential dots ── */
  .cred-dot {
    display: none;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #C4973A;
    flex-shrink: 0;
    margin: 0 16px;
    animation: pulse-dot 2.5s ease-in-out infinite;
  }
  @media (min-width: 640px) {
    .cred-dot { display: inline-block; }
  }
  .cred-dot:nth-child(2) { animation-delay: 0.8s; }
  .cred-dot:nth-child(4) { animation-delay: 1.6s; }

  /* ── Hero card float ── */
  .hero-card {
    animation: float 5s ease-in-out infinite;
  }

  /* ── Responsive grids ── */
  .grid-services {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 640px) {
    .grid-services { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 1024px) {
    .grid-services { grid-template-columns: 1fr 1fr 1fr; }
  }

  .grid-2col {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  @media (min-width: 1024px) {
    .grid-2col { grid-template-columns: 1fr 1fr; }
  }

  .grid-testimonials {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 768px) {
    .grid-testimonials { grid-template-columns: 1fr 1fr; }
  }

  .grid-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
    z-index: 10;
  }
  @media (min-width: 640px) {
    .grid-steps { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 1024px) {
    .grid-steps { grid-template-columns: 1fr 1fr 1fr 1fr; gap: 16px; }
  }

  .grid-stats {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 12px;
  }

  /* ── Responsive section padding ── */
  .section-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 64px 56px;
  }
  @media (max-width: 768px) {
    .section-container { padding: 44px 20px; }
  }

  /* Inner div for page-level hero sections */
  .page-hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 56px;
  }
  @media (max-width: 768px) {
    .page-hero-inner { padding: 0 20px; }
  }

  /* Navbar inner */
  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  @media (max-width: 768px) {
    .nav-inner { padding: 0 20px; }
  }

  /* ── Flex wrap row centered ── */
  .flex-center-wrap {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  /* ── Keyframes ── */
  @keyframes float {
    0%   { transform: translateY(0px); }
    50%  { transform: translateY(-8px); }
    100% { transform: translateY(0px); }
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.6; transform: scale(0.85); }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Respect reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
