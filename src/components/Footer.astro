---
const base = import.meta.env.BASE_URL;
// Footer — dark background (#111827), legal block + copyright left, links right
const year = new Date().getFullYear();
---

<footer role="contentinfo" style="background: #111827;">

  <!-- Legal block -->
  <div style="max-width: 1200px; margin: 0 auto; padding: 24px 56px 0; border-top: 1px solid rgba(255,255,255,0.08);">
    <p style="font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 400; color: rgba(255,255,255,0.6); line-height: 1.7; margin-bottom: 6px;">
      Regulated Canadian Immigration Consultant (RCIC) &nbsp;·&nbsp; Licensed by the College of Immigration and Citizenship Consultants (CICC) &nbsp;·&nbsp; RCIC #: R412247
    </p>
    <p style="font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 300; color: rgba(255,255,255,0.6); line-height: 1.7; max-width: 760px;">
      Immigration programs, eligibility requirements, processing times, and intake windows may change without notice based on IRCC, provincial, or pilot program updates. Information on this website is for general guidance only and does not constitute legal advice.
    </p>
  </div>

  <div style="max-width: 1200px; margin: 0 auto; padding: 16px 56px 24px; display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 16px;">

    <p style="font-family: 'Inter', sans-serif; font-size: 12px; color: rgba(255,255,255,0.5); text-align: center;">
      © {year} Entrypoint Canada Immigration Services. All rights reserved.
      <a
        href="mailto:info@entrypointcanada.com"
        style="color: rgba(255,255,255,0.5); text-decoration: underline; margin-left: 4px; transition: color 0.15s;"
        onmouseover="this.style.color='rgba(255,255,255,0.7)'" onmouseout="this.style.color='rgba(255,255,255,0.5)'"
      >
        info@entrypointcanada.com
      </a>
    </p>

    <nav aria-label="Footer navigation">
      <ul style="display: flex; flex-wrap: wrap; align-items: center; gap: 16px; list-style: none; padding: 0; margin: 0;" role="list">
        <li>
          <a
            href={`${base}programs`}
            style="font-family: 'Inter', sans-serif; font-size: 12px; color: rgba(255,255,255,0.65); text-decoration: none; transition: color 0.15s;"
            onmouseover="this.style.color='rgba(255,255,255,0.9)'" onmouseout="this.style.color='rgba(255,255,255,0.65)'"
          >
            Programs
          </a>
        </li>
        <li>
          <a
            href={`${base}services`}
            style="font-family: 'Inter', sans-serif; font-size: 12px; color: rgba(255,255,255,0.65); text-decoration: none; transition: color 0.15s;"
            onmouseover="this.style.color='rgba(255,255,255,0.9)'" onmouseout="this.style.color='rgba(255,255,255,0.65)'"
          >
            Services
          </a>
        </li>
        <li>
          <a
            href={`${base}about`}
            style="font-family: 'Inter', sans-serif; font-size: 12px; color: rgba(255,255,255,0.65); text-decoration: none; transition: color 0.15s;"
            onmouseover="this.style.color='rgba(255,255,255,0.9)'" onmouseout="this.style.color='rgba(255,255,255,0.65)'"
          >
            About
          </a>
        </li>
        <li>
          <a
            href={`${base}contact`}
            style="font-family: 'Inter', sans-serif; font-size: 12px; color: rgba(255,255,255,0.65); text-decoration: none; transition: color 0.15s;"
            onmouseover="this.style.color='rgba(255,255,255,0.9)'" onmouseout="this.style.color='rgba(255,255,255,0.65)'"
          >
            Contact
          </a>
        </li>
        <li>
          <a
            href={`${base}privacy`}
            style="font-family: 'Inter', sans-serif; font-size: 12px; color: rgba(255,255,255,0.65); text-decoration: none; transition: color 0.15s;"
            onmouseover="this.style.color='rgba(255,255,255,0.9)'" onmouseout="this.style.color='rgba(255,255,255,0.65)'"
          >
            Privacy Policy
          </a>
        </li>
        <li>
          <a
            href={`${base}terms`}
            style="font-family: 'Inter', sans-serif; font-size: 12px; color: rgba(255,255,255,0.65); text-decoration: none; transition: color 0.15s;"
            onmouseover="this.style.color='rgba(255,255,255,0.9)'" onmouseout="this.style.color='rgba(255,255,255,0.65)'"
          >
            Terms of Use
          </a>
        </li>
      </ul>
    </nav>

  </div>
</footer>

<style>
  @media (max-width: 768px) {
    footer > div {
      padding: 20px !important;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    footer > div > p { text-align: center; }
    footer p,
    footer a {
      font-size: 13px !important;
      line-height: 1.75 !important;
    }
  }
</style>
