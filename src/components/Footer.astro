---
const base = import.meta.env.BASE_URL;
// Footer — dark background (#111827), copyright + email left, links right
const year = new Date().getFullYear();
---

<footer role="contentinfo" style="background: #111827;">
  <div style="max-width: 1200px; margin: 0 auto; padding: 24px 56px; display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 16px;">

    <p style="font-family: 'Inter', sans-serif; font-size: 12px; color: rgba(255,255,255,0.5); text-align: center;">
      © {year} Entrypoint Canada Immigration Services. All rights reserved.
      <a
        href="mailto:info@entrypointcanada.com"
        style="color: rgba(255,255,255,0.5); text-decoration: underline; margin-left: 4px; transition: color 0.15s;"
        onmouseover="this.style.color='rgba(255,255,255,0.7)'" onmouseout="this.style.color='rgba(255,255,255,0.5)'"
      >
        info@entrypointcanada.com
      </a>
    </p>

    <nav aria-label="Footer navigation">
      <ul style="display: flex; align-items: center; gap: 16px; list-style: none; padding: 0; margin: 0;" role="list">
        <li>
          <a
            href={`${base}programs`}
            style="font-family: 'Inter', sans-serif; font-size: 12px; color: rgba(255,255,255,0.45); text-decoration: none; transition: color 0.15s;"
            onmouseover="this.style.color='rgba(255,255,255,0.7)'" onmouseout="this.style.color='rgba(255,255,255,0.45)'"
          >
            Programs
          </a>
        </li>
        <li>
          <a
            href={`${base}privacy`}
            style="font-family: 'Inter', sans-serif; font-size: 12px; color: rgba(255,255,255,0.45); text-decoration: none; transition: color 0.15s;"
            onmouseover="this.style.color='rgba(255,255,255,0.7)'" onmouseout="this.style.color='rgba(255,255,255,0.45)'"
          >
            Privacy Policy
          </a>
        </li>
        <li>
          <a
            href={`${base}contact`}
            style="font-family: 'Inter', sans-serif; font-size: 12px; color: rgba(255,255,255,0.45); text-decoration: none; transition: color 0.15s;"
            onmouseover="this.style.color='rgba(255,255,255,0.7)'" onmouseout="this.style.color='rgba(255,255,255,0.45)'"
          >
            Contact
          </a>
        </li>
      </ul>
    </nav>

  </div>
</footer>

<style>
  @media (max-width: 768px) {
    footer > div {
      padding: 20px !important;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    footer > div > p { text-align: center; }
  }
</style>
