---
// ProcessSteps — 4-step horizontal flow with alternating crimson/navy circles and dashed connectors

const steps = [
  {
    number: '1',
    title: 'Free Consultation',
    description: 'We review your situation together and identify the best immigration pathway for you.',
    circleColor: '#8B1A1A',
  },
  {
    number: '2',
    title: 'Document Prep',
    description: 'Sabiha guides you through every required document — no guesswork, no surprises.',
    circleColor: '#3D1215',
  },
  {
    number: '3',
    title: 'Application Filing',
    description: 'Your application is submitted correctly and on time, with full representation before IRCC.',
    circleColor: '#8B1A1A',
  },
  {
    number: '4',
    title: 'Ongoing Support',
    description: 'We stay with you through follow-ups, additional requests, and until you reach your goal.',
    circleColor: '#3D1215',
  },
] as const;
---

<section style="background: #ffffff;" aria-labelledby="process-heading">
  <div class="section-container" style="padding-top: 96px; padding-bottom: 96px;">

    <p style="font-family: 'Inter', sans-serif; font-size: 10px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: #8B1A1A; margin-bottom: 8px; text-align: center;">
      How it works
    </p>
    <h2 id="process-heading" style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(24px, 2.5vw, 32px); font-weight: 600; color: #1A1A2E; line-height: 1.25; margin-bottom: 40px; text-align: center;">
      From first call to final approval
    </h2>
    <p style="font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 300; color: #45465E; line-height: 1.75; margin: 0 auto 40px; max-width: 560px; text-align: center;">
      Each matter moves through a clear process, with eligibility reviewed early, evidence prepared properly, and follow-up handled as the file progresses.
    </p>

    <!-- Steps: horizontal on desktop, vertical on mobile -->
    <div style="position: relative;">
      <!-- Desktop connector line -->
      <div style="display: none; position: absolute; top: 20px; left: calc(12.5% + 20px); right: calc(12.5% + 20px); height: 1px; border-top: 1px dashed #D9D2C5; z-index: 0;" aria-hidden="true" class="connector-line"></div>

      <ol class="grid-steps" role="list">
        {steps.map((step) => (
          <li class="process-step-item" style="display: flex; flex-direction: column; align-items: center; text-align: center; gap: 14px;">

            <!-- Step circle -->
            <div
              class="process-circle"
              style={`width: 48px; height: 48px; border-radius: 50%; background: ${step.circleColor}; display: flex; align-items: center; justify-content: center; flex-shrink: 0; position: relative;`}
            >
              <span class="process-step-number" style="font-family: 'Playfair Display', Georgia, serif; font-size: 18px; font-weight: 600; color: white;" aria-hidden="true">
                {step.number}
              </span>
            </div>

            <div class="process-step-copy">
              <h3 style="font-family: 'Inter', sans-serif; font-size: 15px; font-weight: 600; color: #1A1A2E; margin-bottom: 6px;">{step.title}</h3>
              <p style="font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 300; color: #45465E; line-height: 1.7; max-width: 220px; margin: 0 auto;">
                {step.description}
              </p>
            </div>

          </li>
        ))}
      </ol>
    </div>

  </div>
</section>

<style>
  .process-step-item {
    justify-self: stretch;
  }

  .process-step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1ch;
    line-height: 1;
    font-variant-numeric: lining-nums tabular-nums;
  }

  .process-step-copy {
    display: flex;
    min-height: 112px;
    flex-direction: column;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .connector-line { display: block !important; }
  }

  @media (max-width: 768px) {
    .grid-steps h3 {
      font-size: 16px !important;
    }
    .grid-steps p {
      font-size: 14px !important;
      line-height: 1.75 !important;
      max-width: 240px !important;
    }
    .process-step-copy {
      min-height: auto;
    }
  }
</style>
