---
// CredentialBar — full-width crimson strip with 3 RCIC trust points and gold dot separators
---

<div role="region" aria-label="Professional credentials" style="background: #8B1A1A;">
  <div class="cred-inner" style="max-width: 1200px; margin: 0 auto; padding: 10px 56px; display: flex; flex-wrap: wrap; align-items: center; justify-content: center;">

    <span style="font-family: 'Inter', sans-serif; font-size: 11px; color: rgba(255,255,255,0.9); text-align: center;">
      Registered Canadian Immigration Consultant (RCIC)
    </span>

    <span class="cred-dot" aria-hidden="true"></span>

    <span style="font-family: 'Inter', sans-serif; font-size: 11px; color: rgba(255,255,255,0.9); text-align: center;">
      Member in Good Standing — CICC
    </span>

    <span class="cred-dot" aria-hidden="true"></span>

    <span style="font-family: 'Inter', sans-serif; font-size: 11px; color: rgba(255,255,255,0.9); text-align: center;">
      Authorized to represent before IRCC
    </span>

  </div>
</div>

<style>
  @media (min-width: 768px) and (max-width: 1366px) {
    .cred-inner {
      padding: 12px 36px !important;
    }

    .cred-inner span {
      font-size: 12px !important;
    }
  }

  @media (max-width: 768px) {
    .cred-inner { padding: 10px 20px; gap: 6px 0; }
  }
</style>
