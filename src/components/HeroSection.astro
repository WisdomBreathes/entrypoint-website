---
const base = import.meta.env.BASE_URL;
---
<section style="position: relative; padding: 72px 0 64px; overflow: hidden;">

  <!-- Background image — LCP element: WebP with JPEG fallback, eager + fetchpriority=high -->
  <div style="position: absolute; inset: 0; z-index: 0;">
    <picture>
      <source
        type="image/webp"
        srcset={`${base}images/ampersand-studios-pp_oXEb2H48-unsplash-800w.webp 800w, ${base}images/ampersand-studios-pp_oXEb2H48-unsplash-1400w.webp 1400w`}
        sizes="100vw"
      />
      <img
        src={`${base}images/ampersand-studios-pp_oXEb2H48-unsplash-1400w.webp`}
        loading="eager"
        fetchpriority="high"
        decoding="sync"
        alt=""
        width="1400"
        height="2100"
        style="width: 100%; height: 100%; object-fit: cover; object-position: center 30%;"
      />
    </picture>
    <!-- Burgundy overlay — lets image show through subtly -->
    <div style="position: absolute; inset: 0; background: linear-gradient(180deg, rgba(10,5,5,0.65) 0%, rgba(10,5,5,0.55) 50%, rgba(10,5,5,0.75) 100%);"></div>
  </div>

  <!-- Content -->
  <div class="hero-grid" style="position: relative; z-index: 1; max-width: 1200px; margin: 0 auto; padding: 0 56px; display: grid; grid-template-columns: 1fr 380px; gap: 56px; align-items: center;">

    <!-- Left: Text -->
    <div>
      <!-- Badge -->
      <div style="display: inline-flex; align-items: center; gap: 6px; background: rgba(212,175,98,0.15); border: 1px solid rgba(212,175,98,0.3); color: var(--color-hero-gold-light); font-size: 10px; font-weight: 500; padding: 5px 12px; border-radius: 20px; margin-bottom: 28px; letter-spacing: 0.08em; text-transform: uppercase; font-family: Inter, sans-serif;">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        RCIC Registered · CICC Licensee
      </div>

      <!-- Headline -->
      <h1 class="hero-h1" style="font-family: 'Playfair Display', Georgia, serif; font-size: 62px; font-weight: 700; color: #ffffff; line-height: 1.08; margin: 0 0 22px;">
        Your path<br>to Canada,<br><em style="color: var(--color-hero-gold); font-style: normal;">handled.</em>
      </h1>

      <!-- Subheadline -->
      <p style="font-family: Inter, sans-serif; font-size: 17px; color: rgba(255,255,255,0.82); line-height: 1.7; margin: 0 0 36px; font-weight: 300; max-width: 420px;">
        Professional immigration guidance for applicants who need a clear plan, careful preparation, and regulated representation they can trust.
      </p>

      <!-- Buttons -->
      <div class="hero-buttons" style="display: flex; gap: 12px; margin-bottom: 52px; flex-wrap: wrap;">
        <a href={`${base}contact`} class="btn-gold" style="letter-spacing: 0.01em;">
          Book a free consultation
        </a>
        <a href={`${base}services`} style="display: inline-block; background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.88); padding: 14px 24px; border-radius: 7px; font-size: 15px; font-weight: 400; text-decoration: none; font-family: Inter, sans-serif; border: 1px solid rgba(255,255,255,0.25);">
          Explore services
        </a>
      </div>

      <!-- Trust facts -->
      <div class="hero-stats" style="display: flex; gap: 0; padding-top: 28px; border-top: 1px solid rgba(255,255,255,0.15); align-items: stretch;">
        <div class="stat-item hero-stat" style="padding: 0 22px; border-right: 1px solid rgba(255,255,255,0.12); text-align: center;">
          <div class="hero-stat-title" style="font-family: 'Playfair Display', Georgia, serif; font-size: 21px; font-weight: 600; color: #ffffff;">Licensed RCIC<br>in good standing</div>
          <div class="hero-stat-copy" style="font-family: Inter, sans-serif; font-size: 11px; color: #C4973A; font-weight: 400; margin-top: 4px; letter-spacing: 0.04em;">Authorized by<br>the CICC</div>
        </div>
        <div class="stat-item hero-stat" style="padding: 0 22px; border-right: 1px solid rgba(255,255,255,0.12);">
          <div class="hero-stat-title" style="font-family: 'Playfair Display', Georgia, serif; font-size: 21px; font-weight: 600; color: #ffffff;">Across Canada and overseas</div>
          <div class="hero-stat-copy" style="font-family: Inter, sans-serif; font-size: 11px; color: #C4973A; font-weight: 400; margin-top: 4px; letter-spacing: 0.04em;">Serving clients across multiple pathways</div>
        </div>
        <div class="stat-item hero-stat" style="padding: 0 22px;">
          <div class="hero-stat-title" style="font-family: 'Playfair Display', Georgia, serif; font-size: 21px; font-weight: 600; color: #ffffff;">English, Urdu, Bengali, Hindi</div>
          <div class="hero-stat-copy" style="font-family: Inter, sans-serif; font-size: 11px; color: #C4973A; font-weight: 400; margin-top: 4px; letter-spacing: 0.04em;">Consultations available in multiple languages</div>
        </div>
      </div>
    </div>

    <!-- Right: Consultation card -->
    <div class="hero-card hero-card-reveal" style="background: rgba(255,255,255,0.97); border-radius: 16px; padding: 36px 32px;">
      <div style="font-size: 10px; font-weight: 600; color: var(--color-hero-burgundy-dark); letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 10px; font-family: Inter, sans-serif;">Initial consultation</div>
      <div style="font-family: 'Playfair Display', Georgia, serif; font-size: 24px; font-weight: 600; color: var(--color-hero-brown); margin: 0 0 8px; line-height: 1.2;">Start with a conversation</div>
      <div style="font-family: Inter, sans-serif; font-size: 13px; color: #888; font-weight: 300; margin: 0 0 24px; line-height: 1.55;">A practical first conversation to review your eligibility, likely pathway, and immediate next steps.</div>

      <!-- Checklist -->
      <div style="display: flex; flex-direction: column; gap: 12px; margin-bottom: 28px;">
        <div style="display: flex; align-items: flex-start; gap: 10px; font-family: Inter, sans-serif; font-size: 13px; color: #444; line-height: 1.45;">
          <div style="width: 20px; height: 20px; border-radius: 50%; background: var(--color-hero-cream); display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1px;">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#C4973A" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          30-minute assessment of your immigration profile
        </div>
        <div style="display: flex; align-items: flex-start; gap: 10px; font-family: Inter, sans-serif; font-size: 13px; color: #444; line-height: 1.45;">
          <div style="width: 20px; height: 20px; border-radius: 50%; background: var(--color-hero-cream); display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1px;">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#C4973A" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          Clear explanation of your eligible pathway options
        </div>
        <div style="display: flex; align-items: flex-start; gap: 10px; font-family: Inter, sans-serif; font-size: 13px; color: #444; line-height: 1.45;">
          <div style="width: 20px; height: 20px; border-radius: 50%; background: var(--color-hero-cream); display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1px;">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#C4973A" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          Honest timeline and cost expectations upfront
        </div>
      </div>

      <!-- CTA button -->
      <a href={`${base}contact`} class="btn-burgundy" style="display: block; background: #3D1215; color: #ffffff; padding: 15px; border-radius: 8px; font-size: 14px; font-weight: 600; text-decoration: none; text-align: center; font-family: Inter, sans-serif; margin-bottom: 18px; letter-spacing: 0.01em;">
        Book my free consultation
      </a>

      <!-- RCIC credential -->
      <div style="display: flex; align-items: center; gap: 8px; justify-content: center;">
        <div style="width: 6px; height: 6px; border-radius: 50%; background: #C4973A; flex-shrink: 0;"></div>
        <div style="font-family: Inter, sans-serif; font-size: 11px; color: #45465E; font-weight: 400;">Sabiha Iftakhar · RCIC · CICC Licensee in Good Standing</div>
      </div>
    </div>

  </div>
</section>

<style>
  @keyframes hero-card-reveal {
    from {
      opacity: 0;
      transform: translateY(18px) scale(0.985);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .hero-stat {
    display: flex;
    flex: 1 1 0;
    min-height: 88px;
    flex-direction: column;
    justify-content: center;
    text-align: center;
  }

  .hero-stat-title {
    line-height: 1.25;
  }

  .hero-card-reveal {
    animation: hero-card-reveal 1400ms cubic-bezier(0.22, 1, 0.36, 1) 520ms both,
               float 6s ease-in-out 2.2s infinite;
  }

  @media (min-width: 768px) and (max-width: 1366px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1fr) 340px !important;
      gap: 40px !important;
      padding: 0 36px !important;
    }

    .hero-grid > div:first-child > p {
      font-size: 18px !important;
      line-height: 1.8 !important;
      max-width: 470px !important;
    }

    .hero-buttons {
      margin-bottom: 40px !important;
    }

    .hero-stats {
      padding-top: 22px !important;
    }

    .hero-stat {
      min-height: 104px;
    }

    .hero-stat-title {
      font-size: 24px !important;
      line-height: 1.15 !important;
    }

    .hero-stat-copy {
      font-size: 13px !important;
      line-height: 1.6 !important;
    }
  }

  @media (max-width: 768px) {
    /* Section padding */
    .hero-grid {
      grid-template-columns: 1fr !important;
      padding: 0 20px !important;
      gap: 32px !important;
    }

    /* H1 */
    .hero-h1 {
      font-size: 36px !important;
      margin-bottom: 16px !important;
    }

    /* Subheadline */
    .hero-grid > div:first-child > p {
      font-size: 16px !important;
      line-height: 1.75 !important;
      margin-bottom: 24px !important;
    }

    /* Buttons — stack vertically, full width */
    .hero-buttons {
      flex-direction: column !important;
      gap: 10px !important;
      margin-bottom: 12px !important;
    }
    .hero-buttons a {
      width: 100% !important;
      text-align: center !important;
      display: block !important;
    }

    /* Trust facts — stack cleanly on mobile */
    .hero-stats {
      display: grid !important;
      grid-template-columns: 1fr !important;
      gap: 10px !important;
      padding-top: 0 !important;
      max-width: 320px;
      margin: 0 auto;
      border-top: none !important;
    }
    .hero-stat {
      padding: 10px 0 !important;
      border-right: none !important;
      border-bottom: 1px solid rgba(255,255,255,0.12);
      text-align: center;
      min-height: auto !important;
    }
    .hero-stat:last-child {
      border-bottom: none;
    }
    .hero-stat-title {
      font-size: 20px !important;
      justify-content: center;
    }
    .hero-stat-copy {
      font-size: 12px !important;
      line-height: 1.65 !important;
    }

    /* Card below text on mobile */
    .hero-grid > div:last-child {
      order: 1;
    }
    .hero-grid > div:first-child {
      order: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-card-reveal {
      animation: none !important;
    }
  }

</style>
