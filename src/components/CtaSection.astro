---
// CtaSection — burgundy bg, gold + crimson buttons, 3 credential badges
---

<section style="position: relative; overflow: hidden; background: #3D1215;" aria-labelledby="cta-heading">

  <!-- Background image -->
  <div style="position: absolute; inset: 0; z-index: 0;">
    <img
      src="/images/hermes-rivera-ahHn48-zKWo-unsplash.jpg"
      alt=""
      style="width: 100%; height: 100%; object-fit: cover; object-position: center;"
    />
    <div style="position: absolute; inset: 0; background: rgba(45,8,10,0.75);"></div>
  </div>

  <!-- Content -->
  <div style="position: relative; z-index: 1;">
  <div class="section-container" style="text-align: center;">

    <!-- Crimson accent bar -->
    <div style="width: 48px; height: 3px; background: #8B1A1A; margin: 0 auto 16px;" aria-hidden="true"></div>

    <p style="font-family: 'Inter', sans-serif; font-size: 10px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: #F0D9A8; margin-bottom: 12px;">
      Start your journey
    </p>

    <h2 id="cta-heading" style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(26px, 3vw, 34px); font-weight: 600; color: white; line-height: 1.25; margin-bottom: 12px; max-width: 480px; margin-left: auto; margin-right: auto;">
      Ready to begin your Canadian journey?
    </h2>

    <p style="font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 300; color: rgba(255,255,255,0.8); margin-bottom: 32px; max-width: 400px; margin-left: auto; margin-right: auto; line-height: 1.65;">
      Book a free 30-minute consultation. No pressure, no commitments — just honest answers about your path forward.
    </p>

    <!-- CTA buttons -->
    <div style="display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 12px; margin-bottom: 40px;">
      <a href="/contact" class="btn-gold">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        Book a free consultation
      </a>

      <a href="tel:6479060011" class="btn-crimson">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.35 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 6 6l.94-1.94a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21.5 15z"/>
        </svg>
        Call 647-906-0011
      </a>
    </div>

    <!-- Credential badges -->
    <div style="display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 12px;">

      <div class="cta-badge" style="display: flex; align-items: center; gap: 8px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 10px 16px;">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
             stroke="#C4973A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          <polyline points="9 12 11 14 15 10"/>
        </svg>
        <div style="text-align: left;">
          <p style="font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 600; color: #C4973A; line-height: 1; margin-bottom: 2px;">RCIC Registered</p>
          <p style="font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 300; color: rgba(255,255,255,0.65);">Member in Good Standing</p>
        </div>
      </div>

      <div class="cta-badge" style="display: flex; align-items: center; gap: 8px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 10px 16px;">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
             stroke="#C4973A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="8" r="6"/>
          <path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>
        </svg>
        <div style="text-align: left;">
          <p style="font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 600; color: #C4973A; line-height: 1; margin-bottom: 2px;">ICCRC Member</p>
          <p style="font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 300; color: rgba(255,255,255,0.65);">In Good Standing</p>
        </div>
      </div>

      <div class="cta-badge" style="display: flex; align-items: center; gap: 8px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 10px 16px;">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
             stroke="#C4973A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
          <line x1="8" y1="21" x2="16" y2="21"/>
          <line x1="12" y1="17" x2="12" y2="21"/>
        </svg>
        <div style="text-align: left;">
          <p style="font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 600; color: #C4973A; line-height: 1; margin-bottom: 2px;">IRCC Authorized</p>
          <p style="font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 300; color: rgba(255,255,255,0.65);">All pathways</p>
        </div>
      </div>

    </div>
  </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    /* Credential badges: full-width on mobile so they stack cleanly */
    .cta-badge { width: 100%; justify-content: flex-start; }
  }
</style>
