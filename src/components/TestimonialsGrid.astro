---
const base = import.meta.env.BASE_URL;
// TestimonialsGrid — 2-column grid, crimson left border, gold stars

const testimonials = [
  {
    quote: "Ms. Iftakhar assisted me first with an LMIA matter and later with my permanent residence application. She was organized, clear about each step, and made sure everything was submitted properly. I appreciated how carefully she handled the process and explained what was required at every stage.",
    name: "Karen Roopnarine",
    origin: "LMIA and permanent residence application",
    stars: 5,
  },
  {
    quote: "Ms. Iftakhar handled our permanent residence application for me and my family with a great deal of care and professionalism. She was thorough with the paperwork, patient with our questions, and always straightforward about what was needed. We were very grateful to have her guidance through such an important process.",
    name: "Lilly Anthony",
    origin: "Permanent residence application for her family",
    stars: 5,
  },
  {
    quote: "I reached out to Ms. Iftakhar for help with extending my temporary status in Canada. She reviewed my situation carefully, explained my options clearly, and guided me through the application in a very professional way. The process felt much less stressful with her support.",
    name: "Mudassir",
    origin: "Extension of temporary status in Canada",
    stars: 5,
  },
  {
    quote: "Ms. Iftakhar helped me with my citizenship application and made the process feel much more manageable. She explained the requirements clearly, reviewed everything carefully, and stayed professional throughout. I truly appreciated her guidance during such an important step.",
    name: "Ms. Sonu Rana",
    origin: "Citizenship application",
    stars: 5,
  },
] as const;
---

<section style="position: relative; overflow: hidden; background: #FAF7F2;" aria-labelledby="testimonials-heading">

  <!-- Background image — below the fold, lazy loaded -->
  <div style="position: absolute; inset: 0; z-index: 0;">
    <picture>
      <source
        type="image/webp"
        srcset={`${base}images/denny-rodriguez-dcYh9d4IjCY-unsplash-800w.webp 800w, ${base}images/denny-rodriguez-dcYh9d4IjCY-unsplash-1400w.webp 1400w`}
        sizes="100vw"
      />
      <img
        src={`${base}images/denny-rodriguez-dcYh9d4IjCY-unsplash-1400w.webp`}
        loading="lazy"
        decoding="async"
        alt=""
        width="1400"
        height="933"
        style="width: 100%; height: 100%; object-fit: cover; object-position: center;"
      />
    </picture>
    <div style="position: absolute; inset: 0; background: rgba(250,247,242,0.78);"></div>
  </div>

  <!-- Content -->
  <div style="position: relative; z-index: 1;">
  <div class="section-container">

    <p style="font-family: 'Inter', sans-serif; font-size: 10px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: #8B1A1A; margin-bottom: 8px;">
      Client stories
    </p>
    <h2 id="testimonials-heading" style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(24px, 2.5vw, 32px); font-weight: 600; color: #1A1A2E; line-height: 1.25; margin-bottom: 8px;">
      Real people. Real results.
    </h2>
    <p style="font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 300; color: #5C5C7A; margin-bottom: 32px; max-width: 560px; line-height: 1.7;">
      Shared with permission from real clients whose matters were approved with the support of Entrypoint Canada Immigration Services.
    </p>

    <div class="grid-testimonials">
      {testimonials.map((t) => (
        <article
          class="testimonial-card"
          style="background: #F4F1EB; border: 1px solid #E8E3D9; border-left: 4px solid #8B1A1A; border-radius: 10px; padding: 24px;"
        >
          <!-- Stars -->
          <div role="img" style="display: flex; gap: 2px; margin-bottom: 12px;" aria-label={`${t.stars} out of 5 stars`}>
            {Array.from({ length: t.stars }).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                   fill="#C4973A" stroke="#C4973A" stroke-width="1" aria-hidden="true">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <blockquote>
            <p style="font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 300; font-style: italic; color: #1A1A2E; line-height: 1.7; margin-bottom: 16px;">
              "{t.quote}"
            </p>
            <footer>
              <p style="font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 600; color: #1C2456;">{t.name}</p>
              <p style="font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 300; color: #5C5C7A;">{t.origin}</p>
            </footer>
          </blockquote>
        </article>
      ))}
    </div>

  </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    .grid-testimonials .testimonial-card blockquote > p {
      font-size: 15px !important;
      line-height: 1.8 !important;
    }
    .grid-testimonials .testimonial-card footer p {
      font-size: 13px !important;
    }
  }
</style>
